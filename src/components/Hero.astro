---
import heroImg from "../assets/img1.png";
---

<section class="pt-[104px] min-h-screen bg-[#e9e8d8] overflow-hidden">
  <div class="swiss-container grid grid-cols-1 lg:grid-cols-12 border-x-2 border-black min-h-[calc(100vh-104px)]">
    <div class="lg:col-span-7 min-w-0 overflow-hidden relative p-5 md:p-9 lg:p-12 border-b-2 lg:border-b-0 lg:border-r-2 border-black flex flex-col justify-between speed-lines fade-up">
      <div class="ink-splatter -right-20 -top-20 opacity-30 hidden md:block"></div>
      <div class="relative z-10">
        <div class="flex flex-wrap items-center gap-3 mb-8">
          <span class="zine-label">A&amp;A / ZT-001</span>
          <span class="stamp text-zt-primary">Estudio digital</span>
        </div>

        <div class="relative">
          <h1 class="swiss-display hero-display relative z-10">
            Soluciones<br /><span class="swiss-accent">digitales</span><br />para tu<br />negocio.
          </h1>
        </div>
      </div>

      <div class="relative z-10 grid grid-cols-1 md:grid-cols-7 gap-6 mt-14 pt-5 border-t-[3px] border-black">
        <p class="md:col-span-4 text-base md:text-lg font-medium leading-relaxed bg-[#e9e8d8]">
          Sistemas, comercios digitales y plataformas web para empresas que necesitan crecer sin improvisar.
        </p>
        <div class="md:col-span-3 flex flex-col gap-3">
          <a href="#contacto" class="swiss-button swiss-button--primary">Iniciar proyecto <span aria-hidden="true">→</span></a>
          <a href="#proyectos" class="swiss-button swiss-button--secondary">Ver archivo <span aria-hidden="true">↓</span></a>
        </div>
      </div>
    </div>

    <div class="lg:col-span-5 relative min-h-[34rem] lg:min-h-full bg-black overflow-hidden">
      <div class="absolute inset-5 md:inset-7 border-2 border-white z-20 pointer-events-none"></div>
      <div class="absolute inset-0 halftone">
        <img src={heroImg.src} alt="Equipo colaborando en una solución digital" class="absolute inset-0 w-full h-full object-cover grayscale contrast-150 brightness-90" />
      </div>
      <div class="absolute inset-0 bg-zt-primary mix-blend-multiply opacity-30"></div>
      <div class="absolute top-0 right-0 z-30 bg-[#e9e8d8] text-black border-l-2 border-b-2 border-black px-4 py-3">
        <span class="font-mono text-[8px] uppercase tracking-widest">Development</span>
      </div>
      <div class="absolute left-0 top-1/3 z-30 bg-white text-black border-y-2 border-r-2 border-black p-3 -rotate-2">
        <span class="font-display text-2xl uppercase">Make it<br />work.</span>
      </div>
      <div class="absolute bottom-0 inset-x-0 z-30 grid grid-cols-3 bg-black text-white border-t-2 border-white">
        <div class="p-4 border-r border-white/50">
          <span class="block font-mono text-[8px] text-white/55 uppercase">Focus</span>
          <strong class="block mt-1 text-sm">UX/UI</strong>
        </div>
        <div class="p-4 border-r border-white/50">
          <span class="block font-mono text-[8px] text-white/55 uppercase">Build</span>
          <strong class="block mt-1 text-sm">Code</strong>
        </div>
        <div class="p-4">
          <span class="block font-mono text-[8px] text-white/55 uppercase">Scale</span>
          <strong class="block mt-1 text-sm">Systems</strong>
        </div>
      </div>
    </div>
  </div>
</section>
