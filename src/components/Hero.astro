---
import heroImg from "../assets/img1.png";
---

<section class="pt-20 md:pt-24 min-h-screen border-b border-black bg-[#f5f5f0]">
  <div class="swiss-container min-h-[calc(100vh-5rem)] md:min-h-[calc(100vh-6rem)] grid grid-cols-1 lg:grid-cols-12">
    <div class="lg:col-span-7 flex flex-col justify-between py-12 md:py-16 lg:pr-10 border-r-0 lg:border-r border-black fade-up">
      <div>
        <div class="swiss-kicker">Estudio digital · Chimbote, Perú</div>
        <h1 class="swiss-display max-w-[8ch]">
          Diseño de <span class="swiss-accent">precisión.</span><br />Ingeniería implacable.
        </h1>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-7 gap-8 mt-12 md:mt-20 border-t border-black pt-6">
        <p class="md:col-span-4 text-base md:text-lg leading-relaxed text-zt-text max-w-xl">
          Diseñamos y construimos sistemas, comercios digitales y plataformas web para empresas que necesitan crecer sin improvisar.
        </p>
        <div class="md:col-span-3 flex flex-col gap-3">
          <a href="#contacto" class="swiss-button swiss-button--primary">Iniciar proyecto <span aria-hidden="true">→</span></a>
          <a href="#proyectos" class="swiss-button swiss-button--secondary">Ver proyectos <span aria-hidden="true">↓</span></a>
        </div>
      </div>
    </div>

    <div class="lg:col-span-5 relative min-h-[52vh] lg:min-h-full overflow-hidden bg-black">
      <img src={heroImg.src} alt="Equipo colaborando en una solución digital" class="absolute inset-0 w-full h-full object-cover grayscale contrast-110" />
      <div class="absolute inset-0 bg-zt-primary mix-blend-multiply opacity-35"></div>
      <div class="absolute top-0 left-0 bg-[#f5f5f0] border-r border-b border-black p-4 md:p-6 font-mono text-[10px] uppercase tracking-[0.16em]">
        ZT / 2026<br />Digital systems
      </div>
      <div class="absolute bottom-0 inset-x-0 grid grid-cols-2 bg-black text-white border-t border-white/40">
        <div class="p-5 border-r border-white/40">
          <span class="block font-mono text-[9px] text-white/50 uppercase tracking-widest">Enfoque</span>
          <strong class="block mt-2 text-lg">UX + Ingeniería</strong>
        </div>
        <div class="p-5">
          <span class="block font-mono text-[9px] text-white/50 uppercase tracking-widest">Entrega</span>
          <strong class="block mt-2 text-lg">Web + Sistemas</strong>
        </div>
      </div>
    </div>
  </div>
</section>

