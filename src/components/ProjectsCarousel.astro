---
const projects = [
  { title: "Sistema POS", type: "Restaurante", desc: "Pedidos, inventario, reportes de ventas y menú digital en una sola operación.", tags: ["SQL", "Operaciones", "Retail"], img: "https://images.unsplash.com/photo-1556742049-0cfed4f6a45d?w=900&h=650&fit=crop" },
  { title: "E-Commerce", type: "Retail", desc: "Catálogo, carrito, pagos y administración para vender sin fricción.", tags: ["Commerce", "Pagos", "CRO"], img: "https://images.unsplash.com/photo-1563013544-824ae1b704d3?w=900&h=650&fit=crop" },
  { title: "Gestión de fletes", type: "Logística", desc: "Asignación de viajes para una flotilla de más de 40 camiones y seguimiento satelital.", tags: ["GPS", "PDF", "Datos"], img: "https://images.unsplash.com/photo-1586528116311-ad8dd3c8310d?w=900&h=650&fit=crop" },
  { title: "Portal Metrobus", type: "Transporte", desc: "Rutas, mapas y tiempos de espera conectados a fuentes de datos en tiempo real.", tags: ["REST", "Mapas", "Realtime"], img: "https://images.unsplash.com/photo-1570125909232-eb263c188f7e?w=900&h=650&fit=crop" },
  { title: "Venta de equipo", type: "E-Commerce", desc: "Catálogo con inventario, pagos, órdenes y gestión administrativa.", tags: ["PHP", "API", "MySQL"], img: "https://images.unsplash.com/photo-1472851294608-062f824d29cc?w=900&h=650&fit=crop" },
  { title: "Render Track", type: "Producción", desc: "Monitoreo de equipos, colas de trabajo y notificaciones de producción.", tags: ["Node", "WebSocket", "React"], img: "https://images.unsplash.com/photo-1633356122544-f134324a6cee?w=900&h=650&fit=crop" },
  { title: "Admin Hotel", type: "Hospitalidad", desc: "Reservas, check-in, limpieza, facturación y reportes ejecutivos.", tags: ["Reservas", "Operación", "Reportes"], img: "https://images.unsplash.com/photo-1566073771259-6a8506099945?w=900&h=650&fit=crop" },
];
---

<section id="proyectos" class="swiss-section bg-black text-white">
  <div class="swiss-container">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-y-10 mb-16">
      <div class="lg:col-span-3 font-mono text-xs uppercase tracking-[0.16em] text-zt-mint">04 / Proyectos</div>
      <div class="lg:col-span-9">
        <h2 class="swiss-heading !max-w-[12ch]">Sistemas pensados para <span class="text-zt-mint">trabajar.</span></h2>
        <p class="mt-8 max-w-xl text-white/60 leading-relaxed">Una selección de soluciones creadas para comercio, logística, transporte y operación empresarial.</p>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 border-t border-l border-white/60">
      {projects.map((project, index) => (
        <article class:list={["group border-r border-b border-white/60", index === 0 && "md:col-span-2"]}>
          <div class:list={["grid", index === 0 ? "md:grid-cols-2" : "grid-cols-1"]}>
            <div class:list={["relative overflow-hidden bg-zt-primary", index === 0 ? "aspect-[4/3] md:aspect-[16/9]" : "aspect-[16/10]"]}>
              <img src={project.img} alt={project.title} loading="lazy" class="absolute inset-0 w-full h-full object-cover grayscale contrast-125 opacity-75 group-hover:grayscale-0 group-hover:opacity-100 transition duration-300" />
              <span class="absolute top-0 left-0 bg-zt-primary text-white p-3 font-mono text-[10px] uppercase tracking-widest">{String(index + 1).padStart(2, "0")}</span>
            </div>
            <div class="p-6 md:p-8 flex flex-col justify-between min-h-64">
              <div>
                <span class="font-mono text-[10px] uppercase tracking-[0.16em] text-zt-mint">{project.type}</span>
                <h3 class="mt-3 text-3xl md:text-4xl font-bold tracking-[-0.055em]">{project.title}</h3>
                <p class="mt-4 text-sm md:text-base leading-relaxed text-white/60 max-w-lg">{project.desc}</p>
              </div>
              <div class="mt-8 flex flex-wrap gap-3">
                {project.tags.map((tag) => <span class="font-mono text-[9px] uppercase tracking-widest">[{tag}]</span>)}
              </div>
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

