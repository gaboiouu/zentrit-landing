---
const reasons = [
  { num: "01", title: "Resultados", desc: "Medimos impacto en el negocio, no líneas de código." },
  { num: "02", title: "Velocidad", desc: "Prototipos funcionales y decisiones rápidas." },
  { num: "03", title: "Calidad", desc: "Código mantenible, pruebas y seguridad desde el inicio." },
  { num: "04", title: "Comunicación", desc: "Contacto directo con quienes construyen el producto." },
  { num: "05", title: "Escalabilidad", desc: "Arquitecturas preparadas para crecer sin rehacer." },
  { num: "06", title: "Continuidad", desc: "Acompañamiento después del lanzamiento." },
];
---

<section class="swiss-section bg-white">
  <div class="swiss-container grid grid-cols-1 lg:grid-cols-12 gap-y-14">
    <div class="lg:col-span-4 lg:pr-10 fade-up">
      <div class="swiss-kicker">07 / Diferencial</div>
      <h2 class="swiss-heading !text-[clamp(2.5rem,5vw,4.8rem)]">Socios del producto, no solo proveedores.</h2>
    </div>
    <div class="lg:col-span-8 grid grid-cols-1 sm:grid-cols-2 lg:border-l border-black">
      {reasons.map((reason) => (
        <article class="min-h-48 p-6 border-t lg:border-t-0 border-b border-r border-black flex flex-col justify-between hover:bg-black hover:text-white transition-colors fade-up">
          <span class="font-mono text-xs text-zt-primary">{reason.num}</span>
          <div>
            <h3 class="text-2xl font-bold tracking-[-0.04em] mb-2">{reason.title}</h3>
            <p class="text-sm leading-relaxed opacity-65">{reason.desc}</p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
