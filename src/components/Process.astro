---
const steps = [
  { num: "01", title: "Descubrir", desc: "Negocio, objetivos, usuarios y restricciones." },
  { num: "02", title: "Definir", desc: "Arquitectura, alcance y prioridades verificables." },
  { num: "03", title: "Prototipar", desc: "Flujos y experiencia validados antes del código." },
  { num: "04", title: "Construir", desc: "Desarrollo iterativo con entregas frecuentes." },
  { num: "05", title: "Escalar", desc: "Lanzamiento, medición y mejora continua." },
];
---

<section id="proceso" class="swiss-section bg-[#d3d2bf] speed-lines">
  <div class="swiss-container">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-y-10 mb-14">
      <div class="lg:col-span-8 fade-up">
        <div class="swiss-kicker">04 / Proceso</div>
        <h2 class="swiss-heading">De idea a producto, <span class="swiss-accent">sin perder el orden.</span></h2>
      </div>
      <div class="lg:col-span-4 lg:self-end">
        <div class="zine-panel p-4 bg-[#e9e8d8] -rotate-1">
          <span class="zine-label">Sequence</span>
          <p class="mt-3 text-sm font-medium">Cinco cuadros. Un proceso visible. Cero misterio.</p>
        </div>
      </div>
    </div>

    <ol class="grid grid-cols-1 md:grid-cols-5 border-t-[3px] border-l-[3px] border-black bg-[#e9e8d8]">
      {steps.map((step, index) => (
        <li class:list={["relative min-h-72 p-5 border-r-[3px] border-b-[3px] border-black flex flex-col justify-between overflow-hidden fade-up", index === 2 ? "bg-zt-primary text-white" : "hover:bg-black hover:text-white transition-colors"]}>
          <span class="relative z-10 font-display text-6xl md:text-7xl tracking-[-0.08em]">{step.num}</span>
          <div class="relative z-10">
            <h3 class="font-display text-2xl uppercase tracking-[-0.05em] mb-2">{step.title}</h3>
            <p class="text-sm font-medium leading-relaxed opacity-70">{step.desc}</p>
          </div>
        </li>
      ))}
    </ol>
  </div>
</section>
