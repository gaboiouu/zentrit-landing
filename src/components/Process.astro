---
const steps = [
  { num: "01", title: "Descubrir", desc: "Negocio, objetivos, usuarios y restricciones." },
  { num: "02", title: "Definir", desc: "Arquitectura, alcance y prioridades verificables." },
  { num: "03", title: "Prototipar", desc: "Flujos y experiencia validados antes del código." },
  { num: "04", title: "Construir", desc: "Desarrollo iterativo con entregas frecuentes." },
  { num: "05", title: "Escalar", desc: "Lanzamiento, medición y mejora continua." },
];
---

<section id="proceso" class="swiss-section bg-white">
  <div class="swiss-container">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-y-10 mb-16">
      <div class="lg:col-span-7 fade-up">
        <div class="swiss-kicker">05 / Proceso</div>
        <h2 class="swiss-heading">Orden para convertir una idea en <span class="swiss-accent">producto.</span></h2>
      </div>
      <div class="lg:col-span-5 lg:self-end lg:pl-10 fade-up">
        <p class="swiss-copy !text-base">Un proceso visible reduce incertidumbre, acelera decisiones y mantiene el proyecto alineado.</p>
      </div>
    </div>

    <ol class="grid grid-cols-1 md:grid-cols-5 border-t border-l border-black">
      {steps.map((step) => (
        <li class="min-h-64 p-5 border-r border-b border-black flex flex-col justify-between fade-up">
          <span class="text-5xl md:text-6xl font-black tracking-[-0.08em] text-zt-primary">{step.num}</span>
          <div>
            <h3 class="text-xl font-bold tracking-[-0.04em] mb-2">{step.title}</h3>
            <p class="text-sm leading-relaxed text-zt-text">{step.desc}</p>
          </div>
        </li>
      ))}
    </ol>
  </div>
</section>
