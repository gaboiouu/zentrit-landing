---
import adrianPhoto from "../assets/AdrianSandoval.png";
import aaronPhoto from "../assets/AaronSilva.png";

const team = [
  {
    num: "01",
    name: "Sandoval Ballona Adrián",
    role: "Estrategia & producto",
    specialties: "Estrategia / UX / Dirección",
    photo: adrianPhoto,
    photoClass: "team-photo--adrian",
    blobClass: "team-blob--left",
  },
  {
    num: "02",
    name: "Silva Chorres Aarón",
    role: "Tecnología & desarrollo",
    specialties: "Arquitectura / Código / Entrega",
    photo: aaronPhoto,
    photoClass: "",
    blobClass: "team-blob--right",
  },
];
---

<section id="nosotros" class="swiss-section bg-[#e9e8d8] overflow-hidden">
  <div class="swiss-container">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-y-8 mb-10">
      <div class="lg:col-span-3 fade-up">
        <span class="zine-label">06 / Sobre nosotros</span>
        <p class="mt-5 font-mono text-[9px] font-bold uppercase tracking-widest leading-relaxed">
          Equipo / 02 personas<br />Contacto directo<br />Chimbote — Perú
        </p>
      </div>

      <div class="lg:col-span-9 fade-up">
        <h2 class="swiss-heading !max-w-[14ch]">
          Dos personas. <span class="swiss-accent">Un solo equipo.</span>
        </h2>
        <p class="mt-5 max-w-2xl border-l-4 border-black pl-4 text-base md:text-lg font-medium leading-relaxed">
          Estrategia, diseño y desarrollo directamente con nosotros.
        </p>
      </div>
    </div>

    <div class="mx-auto grid max-w-5xl grid-cols-1 gap-x-16 gap-y-14 md:grid-cols-2">
      {team.map((member) => (
        <article class="group text-center fade-up">
          <div class="team-portrait relative h-80 overflow-hidden md:h-[27rem]">
            <div class:list={["team-blob", member.blobClass]} aria-hidden="true"></div>
            <span class="absolute right-6 top-5 z-0 font-display text-8xl leading-none text-black/10 md:text-9xl" aria-hidden="true">{member.num}</span>
            <img
              src={member.photo.src}
              alt={member.name}
              class:list={["team-photo", member.photoClass]}
              loading="lazy"
            />
          </div>

          <span class="mt-6 inline-block font-mono text-[9px] font-bold uppercase tracking-[0.16em] text-zt-primary">Socio / {member.num}</span>
          <h3 class="mx-auto mt-2 max-w-[16ch] font-display text-3xl uppercase leading-[0.9] tracking-[-0.055em] md:text-4xl">{member.name}</h3>
          <p class="mt-3 font-display text-xl uppercase tracking-[-0.035em] text-black/55">{member.role}</p>
          <p class="mt-3 font-mono text-[8px] font-bold uppercase tracking-[0.14em] text-black/45">{member.specialties}</p>
        </article>
      ))}
    </div>
  </div>
</section>
