            <span class="zine-jp text-4xl md:text-6xl [writing-mode:vertical-rl]">成果</span>
            <div class="space-y-2">
              <span class="block h-3 bg-black"></span>
              <span class="block h-3 bg-zt-primary"></span>
              <span class="block h-3 bg-black w-2/3"></span>
            </div>
          </div>
        </div>
        <div class="grid grid-cols-2 border-x-2 border-b-2 border-black font-mono text-[8px] md:text-[10px] uppercase tracking-wider">
          <div class="p-3 border-r-2 border-black">UX // Interfaces claras</div>
          <div class="p-3">DEV // Código estructurado</div>
        </div>
      </div>
    </div>
  </div>
</section>

