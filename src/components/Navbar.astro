---
const navLinks = [
  { label: "Servici_os", href: "#servicios" },
  { label: "Proyectos", href: "#proyectos" },
  { label: "Proceso", href: "#proceso" },
];

const tickerItems = ["DISEÑO", "CÓDIGO", "SISTEMAS", "PRODUCTOS DIGITALES"];
const tickerLoop = Array.from({ length: 3 }, () => tickerItems).flat();
---

<nav class="fixed inset-x-0 top-0 z-50 bg-[#e9e8d8] border-b-2 border-black" aria-label="Navegación principal">
  <div class="swiss-container h-[72px] grid grid-cols-12 border-x-2 border-black">
    <a href="/" class="col-span-7 md:col-span-3 flex items-center gap-3 px-3 md:px-5 border-r-2 border-black hover:bg-black hover:text-white transition-colors" aria-label="ZentrIT — Inicio">
      <img src="/zt.png" alt="" class="h-11 w-auto object-contain bg-[#e9e8d8]" />
      <div class="leading-none">
        <span class="block font-display text-lg tracking-[-0.06em] uppercase">ZentrIT</span>
        </div>
    </a>

    <div class="hidden md:flex md:col-span-6">
      {navLinks.map((link, index) => (
        <a href={link.href} class="flex-1 flex flex-col items-center justify-center border-r-2 border-black font-mono text-[10px] font-bold uppercase tracking-[0.09em] hover:bg-black hover:text-white transition-colors">
          <span>0{index + 1}</span>
          <span>{link.label}</span>
        </a>
      ))}
    </div>

    <a href="#contacto" class="col-span-5 md:col-span-3 flex items-center justify-between px-4 md:px-6 bg-zt-primary text-white font-mono text-[9px] md:text-[11px] font-bold uppercase tracking-[0.09em] hover:bg-black transition-colors">
      <span>Iniciar proyecto</span>
      <span class="text-lg" aria-hidden="true">↗</span>
    </a>
  </div>

  <div
    class="h-8 bg-black text-white border-t-2 border-black marquee font-mono text-[9px] font-bold uppercase tracking-[0.13em] flex items-center"
    aria-label="Diseño, código, sistemas y productos digitales"
  >
    <div class="marquee-track marquee-track--nav" aria-hidden="true">
      <div class="marquee-group">
        {tickerLoop.map((item) => (
          <span class="marquee-item">
            <span>{item}</span>
            <span>—</span>
          </span>
        ))}
      </div>
      <div class="marquee-group">
        {tickerLoop.map((item) => (
          <span class="marquee-item">
            <span>{item}</span>
            <span>—</span>
          </span>
        ))}
      </div>
    </div>
  </div>
</nav>
