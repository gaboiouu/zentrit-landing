---
const navLinks = [
  { label: "Núcleo", href: "#nucleo" },
  { label: "Servicios", href: "#servicios" },
  { label: "Proyectos", href: "#proyectos" },
  { label: "Proceso", href: "#proceso" },
];
---

<nav class="fixed inset-x-0 top-0 z-50 bg-[#f5f5f0] border-b border-black" aria-label="Navegación principal">
  <div class="swiss-container h-20 md:h-24 grid grid-cols-12 items-stretch">
    <a href="/" class="col-span-6 md:col-span-3 flex items-center gap-3 border-r border-black" aria-label="ZentrIT — Inicio">
      <img src="/zt.png" alt="" class="h-11 md:h-13 w-auto object-contain" />
      <div class="leading-none">
        <span class="block text-sm md:text-base font-black tracking-[-0.03em] uppercase">ZentrIT</span>
        <span class="block mt-1 font-mono text-[7px] md:text-[8px] tracking-[0.18em] uppercase text-zt-text">Arquitectura digital</span>
      </div>
    </a>

    <div class="hidden md:flex md:col-span-6 items-stretch">
      {navLinks.map((link) => (
        <a href={link.href} class="flex-1 flex items-center justify-center border-r border-black font-mono text-[10px] lg:text-xs font-semibold uppercase tracking-[0.1em] hover:bg-black hover:text-white transition-colors">
          {link.label}
        </a>
      ))}
    </div>

    <a href="#contacto" class="col-span-6 md:col-span-3 flex items-center justify-between px-4 md:px-6 bg-zt-primary text-white font-mono text-[10px] md:text-xs font-bold uppercase tracking-[0.1em] hover:bg-black transition-colors">
      <span>Iniciar proyecto</span>
      <span aria-hidden="true">↘</span>
    </a>
  </div>
</nav>

