---
const techs = ["React", "Next.js", "Astro", "TypeScript", "Node.js", "Python", "PostgreSQL", "MongoDB", "Tailwind", "Docker", "Firebase", "GraphQL", "React Native", "Framer Motion"];
---

<section id="tecnologias" class="swiss-section bg-[#f5f5f0]">
  <div class="swiss-container">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-y-10 mb-14">
      <div class="lg:col-span-7 fade-up">
        <div class="swiss-kicker">06 / Tecnología</div>
        <h2 class="swiss-heading">La herramienta correcta para <span class="swiss-accent">cada problema.</span></h2>
      </div>
      <p class="lg:col-span-5 lg:self-end swiss-copy !text-base lg:pl-10 fade-up">Seleccionamos el stack por contexto, mantenimiento y capacidad de crecimiento; nunca por moda.</p>
    </div>

    <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-7 border-t border-l border-black fade-up">
      {techs.map((tech, index) => (
        <div class="aspect-square border-r border-b border-black p-4 flex flex-col justify-between hover:bg-zt-primary hover:text-white transition-colors">
          <span class="font-mono text-[9px] uppercase tracking-widest">{String(index + 1).padStart(2, "0")}</span>
          <strong class="text-sm md:text-base tracking-[-0.03em] break-words">{tech}</strong>
        </div>
      ))}
    </div>
  </div>
</section>

