---
import { Rocket, Building2, Store, CookingPot, Package, Palette } from "lucide-react";

const audiences = [
  { icon: Rocket, title: "Emprendedores", desc: "Presencia digital profesional desde el día uno." },
  { icon: Building2, title: "Empresas", desc: "Automatización de procesos internos y externos." },
  { icon: Store, title: "Negocios locales", desc: "Más clientes con landing optimizadas." },
  { icon: CookingPot, title: "Restaurantes", desc: "Reservas, delivery y carta digital integrados." },
  { icon: Package, title: "Distribuidoras", desc: "Control de ventas, inventario y logística." },
  { icon: Palette, title: "Marcas & Agencias", desc: "Landings visuales que convierten." },
];
---

<section class="py-28 relative">
  <div class="absolute inset-0 bg-gradient-to-b from-zt-surface/30 to-transparent -z-10"></div>
  <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-zt-border to-transparent"></div>

  <div class="max-w-[1400px] mx-auto px-6 md:px-12">
    <div class="mb-14 fade-up">
      <div class="flex items-center gap-3 mb-4">
        <span class="w-8 h-px bg-zt-primary/60"></span>
        <span class="text-[10px] font-mono text-zt-primary font-semibold uppercase tracking-[0.25em]">03 / Audiencia</span>
      </div>
      <h2 class="text-4xl md:text-5xl font-display font-bold text-zt-dark leading-tight">
        Diseñado para negocios<br class="hidden md:block" />
        que quieren <span class="accent-gradient-text">crecer</span>
      </h2>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {audiences.map((a) => (
        <div class="group bg-white/60 backdrop-blur border border-zt-border/50 rounded-xl p-6 flex items-start gap-4 transition-all duration-300 card-hover">
          <div class="w-10 h-10 rounded-lg bg-zt-primary/10 flex items-center justify-center shrink-0 mt-0.5 group-hover:bg-zt-primary/20 transition-colors duration-300">
            <a.icon class="w-5 h-5 text-zt-primary" strokeWidth={1.5} />
          </div>
          <div>
            <h3 class="font-display font-bold text-zt-dark mb-1.5 group-hover:text-zt-primary transition-colors duration-300">{a.title}</h3>
            <p class="text-sm text-zt-text/60 leading-relaxed">{a.desc}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
