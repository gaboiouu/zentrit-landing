---
const audiences = [
  { num: "A", title: "Emprendedores", desc: "Una base digital profesional desde el primer día." },
  { num: "B", title: "Empresas", desc: "Operaciones conectadas, medibles y escalables." },
  { num: "C", title: "Negocios locales", desc: "Más demanda con una presencia enfocada en conversión." },
  { num: "D", title: "Restaurantes", desc: "Reservas, pedidos y operación en un solo ecosistema." },
  { num: "E", title: "Distribuidoras", desc: "Control de ventas, inventario y logística." },
  { num: "F", title: "Marcas & agencias", desc: "Experiencias visuales listas para competir." },
];
---

<section class="swiss-section bg-zt-primary text-white">
  <div class="swiss-container">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-y-10 mb-16">
      <div class="lg:col-span-3 font-mono text-xs uppercase tracking-[0.16em] text-white/70">03 / Para quién</div>
      <h2 class="lg:col-span-9 swiss-heading !max-w-[14ch]">Para negocios que necesitan avanzar, no decorar.</h2>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 border-t border-l border-white">
      {audiences.map((audience) => (
        <article class="min-h-52 p-6 md:p-8 border-r border-b border-white flex flex-col justify-between hover:bg-white hover:text-black transition-colors fade-up">
          <span class="font-mono text-xs uppercase tracking-widest">{audience.num}</span>
          <div>
            <h3 class="text-2xl font-bold tracking-[-0.04em] mb-2">{audience.title}</h3>
            <p class="text-sm leading-relaxed opacity-70 max-w-xs">{audience.desc}</p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

