---
const services = [
  {
    num: "01",
    title: "Sistemas & ERPs",
    desc: "Desarrollo de software a la medida para operaciones empresariales. Digitalizamos flujos de trabajo complejos, gestión de inventarios y análisis de datos en paneles de control unificados y ultrarrápidos.",
    tags: ["Arquitectura Backend", "Bases de Datos", "APIs REST"],
  },
  {
    num: "02",
    title: "E-Commerce Avanzado",
    desc: "Tiendas digitales diseñadas para alto volumen y conversión. Optimizamos cada milisegundo de carga y diseñamos experiencias de compra fluidas que elevan la percepción de tu marca.",
    tags: ["Headless Commerce", "Pasarelas de Pago", "Optimización de Conversión"],
  },
  {
    num: "03",
    title: "Web & Landing Pages",
    desc: "Sitios web corporativos que comunican autoridad. Desde la dirección de arte hasta el despliegue técnico, creamos páginas que capturan leads y dominan visualmente su sector.",
    tags: ["Diseño UI/UX", "Animaciones Fluidas", "SEO Técnico"],
  },
  {
    num: "04",
    title: "Apps Móviles",
    desc: "Aplicaciones nativas e híbridas para iOS y Android con experiencias fluidas, notificaciones push y sincronización en la nube en tiempo real.",
    tags: ["iOS y Android", "Notificaciones Push", "Sincronización Cloud"],
  },
  {
    num: "05",
    title: "Dashboards & Analytics",
    desc: "Paneles de control interactivos con visualización de datos en tiempo real para tomar decisiones informadas con métricas clave de negocio.",
    tags: ["KPI Personalizados", "Gráficos Interactivos", "Tiempo Real"],
  },
  {
    num: "06",
    title: "Automatización & APIs",
    desc: "Procesos repetitivos que dejan de serlo. Conectamos APIs, automatizamos flujos y eliminamos tareas manuales con webhooks inteligentes y notificaciones.",
    tags: ["Integración de APIs", "Flujos Automatizados", "Webhooks Inteligentes"],
  },
];
---

<section id="servicios" class="py-28 relative">
  <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-zt-border to-transparent"></div>

  <div class="max-w-[1400px] mx-auto px-6 md:px-12">
    <div class="flex flex-col md:flex-row md:items-end justify-between mb-16 gap-6 fade-up">
      <div>
        <div class="flex items-center gap-3 mb-4">
          <span class="w-8 h-px bg-zt-primary/60"></span>
          <span class="text-[10px] font-mono text-zt-primary font-semibold uppercase tracking-[0.25em]">02 / Capacidades</span>
        </div>
        <h2 class="text-4xl md:text-5xl font-display font-bold text-zt-dark leading-tight">
          Ingeniería &<br />
          <span class="accent-gradient-text">Servicios</span>
        </h2>
      </div>
      <p class="text-zt-text/60 max-w-sm text-sm font-light leading-relaxed">
        De principio a fin, cada servicio está diseñado para escalar contigo.
      </p>
    </div>

    <div class="space-y-3">
      {services.map((s) => (
        <div class="group relative bg-white/40 hover:bg-white transition-all duration-500 border border-zt-border/60 hover:border-zt-primary/20 rounded-2xl px-6 md:px-10 py-8 fade-up cursor-default">
          <div class="absolute left-0 top-0 bottom-0 w-1 bg-zt-primary/0 group-hover:bg-zt-primary rounded-l-2xl transition-all duration-500"></div>

          <div class="flex flex-col md:flex-row md:items-center gap-6 md:gap-12">
            <div class="hidden md:block w-12 shrink-0">
              <span class="text-3xl font-display font-black text-zt-border/60 group-hover:text-zt-primary/20 transition-colors duration-500">{s.num}</span>
            </div>
            <div class="md:w-72 shrink-0">
              <h3 class="text-2xl font-display font-bold text-zt-dark group-hover:text-zt-primary transition-colors duration-500">
                {s.title}
              </h3>
            </div>
            <p class="text-zt-text/70 text-sm leading-relaxed flex-1">
              {s.desc}
            </p>
            <div class="hidden lg:flex flex-wrap gap-2 shrink-0 max-w-[220px]">
              {s.tags.map((tag) => (
                <span class="px-3 py-1.5 bg-zt-surface border border-zt-border/50 text-[10px] font-mono text-zt-text/60 rounded-lg">{tag}</span>
              ))}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
