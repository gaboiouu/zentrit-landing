---
import MainLayout from "../layouts/MainLayout.astro";
import Navbar from "../components/Navbar.astro";
import Hero from "../components/Hero.astro";
import Philosophy from "../components/Philosophy.astro";
import Services from "../components/Services.astro";
import TargetAudience from "../components/TargetAudience.astro";
import ProjectsCarousel from "../components/ProjectsCarousel.astro";
import Process from "../components/Process.astro";
import Technologies from "../components/Technologies.astro";
import WhyChooseUs from "../components/WhyChooseUs.astro";
import Footer from "../components/Footer.astro";
import ContactForm from "../components/ContactForm.jsx";
import WhatsAppButton from "../components/WhatsAppButton.jsx";
---

<MainLayout>
  <Navbar />
  <main>
    <Hero />
    <Philosophy />
    <Services />
    <TargetAudience />
    <ProjectsCarousel />
    <Process />
    <Technologies />
    <WhyChooseUs />

    <section id="contacto" class="border-t border-black bg-[#f5f5f0]">
      <div class="swiss-container grid grid-cols-1 lg:grid-cols-12">
        <div class="lg:col-span-5 bg-black text-white p-7 md:p-12 lg:border-r border-black flex flex-col justify-between min-h-[32rem] fade-up">
          <div>
            <div class="font-mono text-[10px] uppercase tracking-[0.18em] text-zt-mint">08 / Contacto</div>
            <h2 class="mt-8 text-5xl md:text-7xl font-black tracking-[-0.07em] leading-[0.88]">Hagamos algo<br /><span class="text-zt-mint">útil.</span></h2>
          </div>
          <div class="grid grid-cols-2 gap-6 items-end mt-12">
            <img src="/zenti.png" alt="Zenti, asistente de ZentrIT" class="zenti-mascot w-full max-w-52 object-contain" />
            <div class="font-mono text-[9px] md:text-[10px] uppercase tracking-widest leading-relaxed text-white/60">
              Chimbote, Perú<br />
              Lun–Vie / 09–18h<br />
              Respuesta / 24h
            </div>
          </div>
        </div>

        <div class="lg:col-span-7 p-7 md:p-12 lg:p-16 fade-up">
          <div class="max-w-2xl">
            <p class="text-xl md:text-2xl font-semibold tracking-[-0.035em] leading-snug mb-12">Cuéntanos el problema, el contexto y el resultado que necesitas. Nosotros ordenamos el resto.</p>
            <ContactForm client:load />
          </div>
        </div>
      </div>
    </section>
  </main>
  <WhatsAppButton />
  <Footer />
</MainLayout>
