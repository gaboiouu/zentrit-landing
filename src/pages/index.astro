---
import MainLayout from "../layouts/MainLayout.astro";

import Navbar from "../components/Navbar.astro";
import Hero from "../components/Hero.astro";
import Philosophy from "../components/Philosophy.astro";
import Services from "../components/Services.astro";
import TargetAudience from "../components/TargetAudience.astro";
import Process from "../components/Process.astro";
import Technologies from "../components/Technologies.astro";
import WhyChooseUs from "../components/WhyChooseUs.astro";
import Footer from "../components/Footer.astro";
import ProjectsCarousel from "../components/ProjectsCarousel.astro";
import ContactForm from "../components/ContactForm.jsx";
import WhatsAppButton from "../components/WhatsAppButton.jsx";
---

<MainLayout>
  <Navbar />
  <Hero />
  <Philosophy />
  <Services />
  <TargetAudience />
  <ProjectsCarousel />
  <Process />
  <Technologies />
  <WhyChooseUs />
  <section id="contacto" class="relative min-h-[600px] grid grid-cols-1 lg:grid-cols-12 overflow-hidden bg-white">
    <div class="lg:col-span-6 relative min-h-[400px] lg:min-h-[600px] flex items-center justify-center p-8 md:p-12">
      <div class="relative w-full max-w-md aspect-square group">
        <img
          src="/zenti.png"
          alt="Zenti"
          class="zenti-mascot w-full h-full object-contain drop-shadow-2xl"
        />
        <div class="absolute -inset-4 bg-gradient-to-br from-zt-primary/5 via-zt-secondary/5 to-zt-mint/5 rounded-full blur-3xl -z-10 animate-pulse-slow"></div>
      </div>
    </div>
    <div class="lg:col-span-6 flex items-center justify-center px-6 md:px-12 py-16 lg:py-0">
      <div class="max-w-lg w-full">
        <div class="flex items-center gap-3 mb-4">
          <span class="w-8 h-px bg-zt-primary/60"></span>
          <span class="text-[10px] font-mono text-zt-primary font-semibold uppercase tracking-[0.25em]">Contacto</span>
        </div>
        <h2 class="text-3xl md:text-4xl font-display font-bold text-zt-dark mb-2">
          Trabajemos <span class="accent-gradient-text">juntos</span>
        </h2>
        <p class="text-zt-text/60 text-sm mb-8 max-w-md">
          Cuéntanos sobre tu proyecto y te respondemos en máximo 24 horas.
        </p>
        <ContactForm />
      </div>
    </div>
  </section>
  <WhatsAppButton />
  <Footer />
</MainLayout>
