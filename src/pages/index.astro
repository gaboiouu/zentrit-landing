---
import MainLayout from "../layouts/MainLayout.astro";
import Navbar from "../components/Navbar.astro";
import Hero from "../components/Hero.astro";
import Services from "../components/Services.astro";
import TargetAudience from "../components/TargetAudience.astro";
import ProjectsCarousel from "../components/ProjectsCarousel.astro";
import Process from "../components/Process.astro";
import Technologies from "../components/Technologies.astro";
import WhyChooseUs from "../components/WhyChooseUs.astro";
import Footer from "../components/Footer.astro";
import ContactForm from "../components/ContactForm.jsx";
import WhatsAppButton from "../components/WhatsAppButton.jsx";
---

<MainLayout>
  <Navbar />
  <main>
    <Hero />
    <Services />
    <TargetAudience />
    <ProjectsCarousel />
    <Process />
    <Technologies />
    <WhyChooseUs />

    <section id="contacto" class="swiss-section !py-0 bg-[#d3d2bf] overflow-hidden">
      <div class="swiss-container grid grid-cols-1 lg:grid-cols-12 border-x-[3px] border-black">
        <div class="lg:col-span-5 relative bg-black text-white p-6 md:p-10 lg:border-r-[3px] border-black flex flex-col justify-between min-h-[38rem] fade-up overflow-hidden halftone">
          <div class="ink-splatter -right-8 top-24 opacity-35 invert"></div>
          <div>
            <span class="zine-label !bg-zt-primary">07 / Contacto / 連絡</span>
            <div class="zine-jp text-7xl md:text-9xl text-white/10 leading-none mt-4" aria-hidden="true">連絡</div>
            <h2 class="relative z-10 mt-[-2rem] font-display text-5xl md:text-7xl uppercase tracking-[-0.07em] leading-[0.8]">Hagamos<br />algo<br /><span class="text-zt-mint">útil.</span></h2>
          </div>
          <div class="relative z-10 grid grid-cols-2 gap-4 items-end mt-12 border-2 border-white p-3 bg-black">
            <img src="/zenti.png" alt="Zenti, asistente de ZentrIT" class="zenti-mascot w-full max-w-56 object-contain bg-[#e9e8d8]" />
            <div class="font-mono text-[8px] md:text-[9px] uppercase tracking-widest leading-relaxed text-white/65">
              Chimbote, Perú<br />
              Lun–Vie / 09–18h<br />
              Respuesta / 24h
            </div>
          </div>
        </div>

        <div class="lg:col-span-7 p-5 md:p-10 lg:p-12 speed-lines fade-up">
          <div class="max-w-2xl">
            <div class="zine-label mb-5">Project intake / 受付</div>
            <p class="font-display text-3xl md:text-5xl uppercase tracking-[-0.06em] leading-[0.86] mb-10">Cuéntanos el problema. <span class="text-zt-primary">Nosotros ordenamos el resto.</span></p>
            <ContactForm client:load />
          </div>
        </div>
      </div>
    </section>
  </main>
  <WhatsAppButton />
  <Footer />
</MainLayout>
